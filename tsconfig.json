{
  "compilerOptions": {
      "target": "es5",
      "module": "es2015",
      "moduleResolution": "node",
      "noImplicitReturns": true,
      "outDir": "./built/",
      "sourceMap": true,
      "strict": true,
      "experimentalDecorators" : true,
      "types": ["vuetify", "pinia", "vue-loader"],
      "allowJs": true,
      "strictPropertyInitialization": false,
      "jsx" : "react-jsx",
      "typeRoots" : ["./node_modules/@types", "./types"]
  },
  "include": [
      "./src/**/*",
      "./src/*.d.ts",
      "./types/*.d.ts"
  ]
}