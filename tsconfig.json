{
  "compilerOptions": {
      "target": "es5",
      "module": "es2015",
      "moduleResolution": "node",
      "noImplicitReturns": true,
      "outDir": "./built/",
      "sourceMap": true,
      "strict": true,
      "experimentalDecorators" : true,
      "types": ["vuetify"],
      "allowJs": true,
      "strictPropertyInitialization": false,
      "jsx" : "react",
      "typeRoots" : ["./node_modules/@types", "./typings"]
  },
  "include": [
      "./src/**/*",
      "./src/*.d.ts",
      "typings"
  ]
}